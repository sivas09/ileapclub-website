generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  FACILITATOR
  PARENT
  STUDENT
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  firstName    String
  lastName     String
  role         Role
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  parentStudents StudentParent[] @relation("ParentUser")
  studentProfile  Student?
  facilitator     ClubFacilitator[]
}

model Centre {
  id        String   @id @default(cuid())
  name      String
  province  String
  city      String
  address   String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  clubs Club[]
}

model Club {
  id        String   @id @default(cuid())
  centreId  String
  name      String
  program   String
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  centre       Centre            @relation(fields: [centreId], references: [id])
  students     Student[]
  facilitators ClubFacilitator[]
  meetings     Meeting[]
}

model Student {
  id        String   @id @default(cuid())
  userId    String   @unique
  clubId    String?
  grade     String
  bandLevel String   @default("White")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user    User            @relation(fields: [userId], references: [id])
  club    Club?           @relation(fields: [clubId], references: [id])
  parents StudentParent[]
  roleSlots MeetingRoleSlot[]
  attendance MeetingAttendance[]
  roleScores MeetingRoleScore[]
  requirementProgress StudentRequirementProgress[]
}

model StudentParent {
  id        String   @id @default(cuid())
  parentId  String
  studentId String
  createdAt DateTime @default(now())

  parent  User    @relation("ParentUser", fields: [parentId], references: [id])
  student Student @relation(fields: [studentId], references: [id])

  @@unique([parentId, studentId])
}

model ClubFacilitator {
  id            String   @id @default(cuid())
  clubId        String
  facilitatorId String
  createdAt     DateTime @default(now())

  club        Club @relation(fields: [clubId], references: [id])
  facilitator User @relation(fields: [facilitatorId], references: [id])

  @@unique([clubId, facilitatorId])
}

model RoleDefinition {
  id          String   @id @default(cuid())
  name        String   @unique
  description String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  meetingSlots MeetingRoleSlot[]
}

model Meeting {
  id           String   @id @default(cuid())
  clubId       String
  title        String
  templateType String
  meetingDate  DateTime
  startTime    String
  location     String?
  isRoleLocked Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  club      Club              @relation(fields: [clubId], references: [id])
  roleSlots MeetingRoleSlot[]
  attendance MeetingAttendance[]
  roleScores MeetingRoleScore[]
}

model MeetingRoleSlot {
  id               String   @id @default(cuid())
  meetingId        String
  roleDefinitionId String
  slotLabel        String
  sortOrder        Int      @default(0)
  assignedStudentId String?
  assignedByUserId String?
  assignedAt       DateTime?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  meeting        Meeting        @relation(fields: [meetingId], references: [id])
  roleDefinition RoleDefinition @relation(fields: [roleDefinitionId], references: [id])
  assignedStudent Student?      @relation(fields: [assignedStudentId], references: [id])
  score MeetingRoleScore?

  @@index([meetingId])
  @@unique([meetingId, sortOrder])
}

model MeetingAttendance {
  id             String   @id @default(cuid())
  meetingId      String
  studentId      String
  status         String   @default("PRESENT")
  notes          String?
  markedByUserId String?
  markedAt       DateTime @default(now())
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  meeting Meeting @relation(fields: [meetingId], references: [id])
  student Student @relation(fields: [studentId], references: [id])

  @@unique([meetingId, studentId])
}

model MeetingRoleScore {
  id             String   @id @default(cuid())
  meetingId      String
  roleSlotId     String   @unique
  studentId      String
  score          Int
  feedback       String?
  scoredByUserId String?
  scoredAt       DateTime @default(now())
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  meeting  Meeting         @relation(fields: [meetingId], references: [id])
  roleSlot MeetingRoleSlot @relation(fields: [roleSlotId], references: [id])
  student  Student         @relation(fields: [studentId], references: [id])

  @@index([meetingId])
  @@index([studentId])
}

model BandRequirement {
  id          String   @id @default(cuid())
  bandLevel   String
  name        String
  description String
  requirementType String
  targetCount Int      @default(1)
  sortOrder   Int      @default(0)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  progress StudentRequirementProgress[]

  @@unique([bandLevel, name])
  @@index([bandLevel])
}

model StudentRequirementProgress {
  id            String   @id @default(cuid())
  studentId     String
  requirementId String
  currentCount  Int      @default(0)
  isCompleted   Boolean  @default(false)
  completedAt   DateTime?
  notes         String?
  updatedByUserId String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  student     Student         @relation(fields: [studentId], references: [id])
  requirement BandRequirement @relation(fields: [requirementId], references: [id])

  @@unique([studentId, requirementId])
  @@index([studentId])
}
